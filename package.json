{
  "name": "zai-code-review",
  "version": "1.0.0",
  "description": "AI-powered code review GitHub Action using Z.ai API with inline comments, code suggestions, and PR summaries",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit && npm run build"
  },
  "keywords": [
    "github-action",
    "code-review",
    "ai",
    "zai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/rest": "^22.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.3.3"
  }
}
